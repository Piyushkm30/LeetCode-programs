class Solution {
public:
    int compareVersion(string version1, string version2) {
        int j = 0;
        int i = 0;
        int maxx = max(version1.size(), version2.size());
        for(int k = 0; k < maxx; ++k)
        {
            int a = 0, b = 0;
            string s = "";
            string s1 = "";
            while(i < version1.size() && version1[i] != '.')
            {
                s += version1[i];
                i++;
            }
            if(s.size() > 0)  a = stoi(s);
            while(j < version2.size() && version2[j] != '.')
            {
                s1 += version2[j];
                j++;
            }
            if(s1.size() > 0) b = stoi(s1);
            cout << a << " " << b << endl;
            if(a > b) return 1;
            else if(a < b) return -1;
            i++;
            j++;
        }
        return 0;
    }
};
