public class MinStack {
    private Stack<int> stack;
    private Stack<int> minimumPerValueStack;

    public MinStack() {
        stack = new Stack<int>();
        minimumPerValueStack = new Stack<int>();
    }
    
    public void Push(int val) {
        stack.Push(val);

        val = Math.Min(val, minimumPerValueStack.Count == 0 ? val : minimumPerValueStack.Peek());
        minimumPerValueStack.Push(val);
    }
    
    public void Pop() {
        stack.Pop();
        minimumPerValueStack.Pop();
    }
    
    public int Top() {
        return stack.Peek();
    }
    
    public int GetMin() {
        return minimumPerValueStack.Peek();
    }
}
