class Solution {
public:
    Node* copyRandomList(Node* head) {
        if (!head) return NULL;

        unordered_map<Node*, Node*> mpp;
        Node* curNode = head;

        // Step 1: Create copy of each node
        while (curNode) {
            mpp[curNode] = new Node(curNode->val);
            curNode = curNode->next;
        }

        // Step 2: Connect next and random pointers
        curNode = head;
        while (curNode) {
            mpp[curNode]->next = mpp[curNode->next];
            mpp[curNode]->random = mpp[curNode->random];
            curNode = curNode->next;
        }

        return mpp[head];
    }
};
